<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>EndfieldEssenceChecker</AssemblyName>
    <RootNamespace>EndfieldEssenceChecker</RootNamespace>
    <Product>EndfieldEssenceChecker</Product>
    <Title>EndfieldEssenceChecker</Title>
    <DefaultItemExcludes>$(DefaultItemExcludes);bin\**;obj\**;bin-codex*\**;obj-codex*\**</DefaultItemExcludes>
  </PropertyGroup>
  <ItemGroup>
    <None Include="winocr.ps1" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
